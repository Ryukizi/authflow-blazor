@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using System.ComponentModel.DataAnnotations
@using Validacao_1.Shared.Services
@using System.Text.RegularExpressions
@using Supabase
@using Validacao_1.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IValidador Validador
@inject Client SupabaseClient
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<div class="container mt-4">
    <AuthorizeView>
        <Authorized>
            <div class="alert alert-success">
                🎉 Olá, <strong>@context.User.Identity?.Name</strong>! Você fez login com sucesso.
            </div>

            <hr />
            <h3>Área de Teste de Perfis:</h3>

            <AuthorizeView Roles="Admin" Context="adminContext">
                <div class="card border-danger mb-3">
                    <div class="card-header bg-danger text-white">👑 Visão do Administrador</div>
                    <div class="card-body text-danger">
                        <p class="card-text">Se você está vendo esta caixa vermelha, o seu perfil no Supabase é <strong>Admin</strong> e o Blazor leu com sucesso!</p>
                    </div>
                </div>
            </AuthorizeView>

            <AuthorizeView Roles="Usuario" Context="userContext">
                <div class="card border-primary mb-3">
                    <div class="card-header bg-primary text-white">👤 Visão do Usuário Comum</div>
                    <div class="card-body text-primary">
                        <p class="card-text">Se você está vendo esta caixa azul, o seu perfil no Supabase é <strong>Usuario</strong> comum!</p>
                    </div>
                </div>
            </AuthorizeView>

            <button class="btn btn-secondary mt-3" @onclick="ExecutarLogout">Sair do Sistema</button>
        </Authorized>

        <NotAuthorized>
            <div class="alert alert-warning">
                ⚠️ Você está deslogado. Vá para a página de login.
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<h1>Cadastro!</h1>

<div class="alert alert-primary mt-3" role="alert">
    <strong>Validação bem-sucedida:</strong>
    <div>@respostaBasica</div>
    <div>@NomeResposta</div>
    <div>@emailResposta</div>
    <div>@senhaResposta</div>
</div>

@if (mostrarCampoCodigo)
{
    <div class="alert alert-success mt-3" role="alert">
        <strong>Digite o código de verificação enviado para seu email:</strong>
        <input type="text" @bind="codigoEnviado" placeholder="Código de verificação" />
        <button class="btn btn-primary mt-2" @onclick="VerificarCodigo">Verificar Código</button>
    </div>
}

<h1>Validação idade</h1>
<input type="number"
       pattern="[0-9]*"
       @bind="idade"
       onkeypress="return event.key !== '.' && event.key !== ',';" />


<h1>Validação Nome </h1>
<input type="text"
       pattern="[A-Za-zÀ-ÿ\s]+"
       inputmode="text"
       oninput="this.value = this.value.replace(/[0-9]/g, '')"
       @bind="nome"
       placeholder="Digite apenas letras"
       onkeypress="return event.key !== '.' && event.key !== ',';" />
<p></p>

<h1>Validação Email </h1>
<input type="text"
       @bind="email"
       placeholder="Digite seu Email" />

<h1>Validação Senha </h1>
<input type="text"
       @bind="senha"
       placeholder="Digite sua Senha" />

<button class="btn btn-primary" @onclick="async () => await OnClickPessoa(idade, nome, email, senha)">Click me</button>

<button class=" btn btn-danger" @onclick="ExecutarLogout">
    Sair da Conta
</button>

@code {
    public string respostaBasica = "";
    private string emailResposta = "";
    private string senhaResposta = "";
    private string NomeResposta = "";
    private int idade;
    private string nome = "";
    private string email = "";
    private string senha = "";
    private bool mostrarCampoCodigo = false;
    private string codigoEnviado = "";
    private int CodigoCorreto;

    public async Task getValidador(Pessoa pessoa)
    {
        var resultado = await Validador.EntradaDeDados(pessoa);

        if (resultado == null || resultado.Count == 0) return;

        if (resultado.Count == 1)
        {
            respostaBasica = resultado[0];
            emailResposta = "";
            senhaResposta = "";
            NomeResposta = "";
            mostrarCampoCodigo = false;
        }
        else
        {
            // Pega os retornos do seu validador com segurança
            emailResposta = resultado.Count > 0 ? resultado[0] : "";
            senhaResposta = resultado.Count > 1 ? resultado[1] : "";
            NomeResposta = resultado.Count > 2 ? resultado[2] : "";

            // Normaliza os textos para minúsculo para evitar brigas com maiúsculas/minúsculas
            string emailCheck = emailResposta.ToLower();
            string senhaCheck = senhaResposta.ToLower();
            string nomeCheck = NomeResposta.ToLower();

            // 🟢 SOLUÇÃO DEFINITIVA: Só bloqueia se houver palavras clássicas de erro.
            // Se as strings forem de sucesso (independente de acentos tortos), ele deixa passar!
            if (!emailCheck.Contains("erro") && !emailCheck.Contains("já cadastrado") && !emailCheck.Contains("vazio") && !emailCheck.Contains("inválido") &&
                !senhaCheck.Contains("erro") && !senhaCheck.Contains("fraca") && !senhaCheck.Contains("curta") && !senhaCheck.Contains("inválida") &&
                !nomeCheck.Contains("erro") && !nomeCheck.Contains("vazio") && !nomeCheck.Contains("inválido"))
            {
                respostaBasica = "Dados validados com sucesso! Enviando código...";
                mostrarCampoCodigo = true; // 🌟 Abre a caixa do código!
                CodigoCorreto = new Random().Next(1000, 10000);
                _ = Task.Run(async () => await Validador.EnviarEmailCodigo(email, CodigoCorreto));
            }
            else
            {
                respostaBasica = "Existem erros de validação no formulário.";
                mostrarCampoCodigo = false; // Mantém fechado se houver erros reais
            }
        }
    }

    private async Task VerificarCodigo()
    {
        if (codigoEnviado == CodigoCorreto.ToString())
        {
            try
            {
                // 1. Cria o usuário para a sua tabela
                var novoUsuario = new Usuario
                {
                    Nome = nome,
                    Idade = idade,
                    Email = email,
                    Senha = Validador.HashPassword(senha)
                };

                // 2. Salva nas tabelas do Supabase
                await SupabaseClient.From<Usuario>().Insert(novoUsuario);
                var cadastro = await SupabaseClient.Auth.SignUp(email, senha);

                if (cadastro != null)
                {
                    // Injeta o perfil simulado para o Blazor reconhecer como "Usuario"
                    var sessaoSimuladaCadastro = new
                    {
                        user = new
                        {
                            email = email,
                            id = cadastro.User?.Id ?? "0",
                            perfil = "Usuario"
                        }
                    };

                    var sessionJson = System.Text.Json.JsonSerializer.Serialize<object>(sessaoSimuladaCadastro);
                    await ((SupabaseAuthStateProvider)AuthStateProvider).MarcarComoLogado(sessionJson);
                    StateHasChanged();
                }

                respostaBasica = "Código verificado e Usuário cadastrado no Supabase com sucesso!";

                // 🟢 SÓ FECHA A CAIXA DEPOIS QUE SALVOU COM SUCESSO:
                mostrarCampoCodigo = false;
            }
            catch (Exception ex)
            {
                respostaBasica = $"Código correto, mas erro ao salvar no banco: {ex.Message}";
                Console.WriteLine($"Erro no Insert: {ex.ToString()}");
            }
        }
        else
        {
            respostaBasica = "Código de verificação incorreto. Tente novamente.";
            // 🟢 SE ERRAR O CÓDIGO, MANTÉM A CAIXA ABERTA:
            mostrarCampoCodigo = true;
        }
    }

    private async Task OnClickPessoa(int idade, string nome, string email, string senha)
    {
        var _pessoa = new Pessoa
        {
            Nome = nome,
            Idade = idade,
            Email = email,
            Senha = senha
        };
        await getValidador(_pessoa);
    }

    private async Task ExecutarLogout()
    {
        try
        {
            await SupabaseClient.Auth.SignOut();
            await ((SupabaseAuthStateProvider)AuthStateProvider).MarcarComoDeslogado();

            respostaBasica = "Você foi deslogado com sucesso!";
            mostrarCampoCodigo = false;

            Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            respostaBasica = $"Erro ao deslogar: {ex.Message}";
        }
    }

    public class Pessoa
    {
        public string Nome { get; set; } = string.Empty;
        public int Idade { get; set; }
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }
}
