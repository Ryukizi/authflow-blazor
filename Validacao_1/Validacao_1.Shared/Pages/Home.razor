@page "/"
@using System.ComponentModel.DataAnnotations
@using Validacao_1.Shared.Services
@using System.Text.RegularExpressions
@using Supabase 
@inject IValidador Validador
@inject Client SupabaseClient 

<PageTitle>Home</PageTitle>

<h1>Cadastro!</h1>

<div class="alert alert-primary mt-3" role="alert">
    <strong>Validação bem-sucedida:</strong>
    <div>@respostaBasica</div>
    <div>@NomeResposta</div>
    <div>@emailResposta</div>
    <div>@senhaResposta</div>
</div>

@if(mostrarCampoCodigo)
{
    <div class="alert alert-success mt-3" role="alert">
        <strong>Digite o código de verificação enviado para seu email:</strong>
        <input type="text" @bind="codigoEnviado" placeholder="Código de verificação" />
        <button class="btn btn-primary mt-2" @onclick="VerificarCodigo">Verificar Código</button>
    </div>
}

<h1>Validação idade</h1> 
<input type="number" 
    pattern="[0-9]*" 
    @bind="idade" 
    onkeypress="return event.key !== '.' && event.key !== ',';" />


<h1>Validação Nome </h1> 
<input type="text"
       pattern="[A-Za-zÀ-ÿ\s]+"
       inputmode="text"
       oninput="this.value = this.value.replace(/[0-9]/g, '')"
       @bind="nome"
       placeholder="Digite apenas letras"
       onkeypress="return event.key !== '.' && event.key !== ',';" />
<p></p>

<h1>Validação Email </h1>
<input type="text"
       @bind="email"
       placeholder="Digite seu Email"/>

<h1>Validação Senha </h1>
<input type="text"
       @bind="senha"
       placeholder="Digite sua Senha" />

<button class="btn btn-primary" @onclick="async () => await OnClickPessoa(idade, nome, email, senha)">Click me</button>

@code {
    public string respostaBasica = "";
    private string emailResposta = "";
    private string senhaResposta = "";
    private string NomeResposta = "";
    private int idade;
    private string nome = "";
    private string email = "";
    private string senha = "";
    private bool mostrarCampoCodigo = false;
    private string codigoEnviado = "";
    private int CodigoCorreto;

    public async Task getValidador(Pessoa pessoa)
    {
        var resultado = await Validador.EntradaDeDados(pessoa);

        if (resultado == null || resultado.Count == 0) return;

        if (resultado.Count == 1)
        {
            respostaBasica = resultado[0];
            emailResposta = "";
            senhaResposta = "";
            NomeResposta = "";
            mostrarCampoCodigo = false;
        }
        else
        {
            respostaBasica = "";
            // Garante que não vai dar erro de índice se a lista vier incompleta
            emailResposta = resultado.Count > 0 ? resultado[0] : "";
            senhaResposta = resultado.Count > 1 ? resultado[1] : "";
            NomeResposta = resultado.Count > 2 ? resultado[2] : "";

            // Agora a comparação bate exatamente com "Senha válida"
            if (emailResposta == "Email válido" && senhaResposta == "Senha valída" && NomeResposta == "Nome valído")
            {
                mostrarCampoCodigo = true;
                CodigoCorreto = new Random().Next(1000, 10000);

                // Rodando em Background para não travar a tela enquanto o e-mail envia
                _ = Task.Run(async () => await Validador.EnviarEmailCodigo(email, CodigoCorreto));
            }
            else
            {
                mostrarCampoCodigo = false;
            }
        }
    }

    // Mudamos para async Task para podermos usar o await do Supabase
    private async Task VerificarCodigo()
    {
        if(codigoEnviado == CodigoCorreto.ToString())
        {
            try
            {
                // 1. Criamos o objeto do usuário baseado no que está na tabela do banco
                var novoUsuario = new Usuario
                {
                    Nome = nome,
                    Idade = idade,
                    Email = email,
                    Senha = Validador.HashPassword(senha) // Idealmente aqui você usaria a senha encriptada do hash
                };

                // 2. MANDANDO PARA O SUPABASE DE VERDADE!
                await SupabaseClient.From<Usuario>().Insert(novoUsuario);

                respostaBasica = "Código verificado e Usuário cadastrado no Supabase com sucesso!";
                mostrarCampoCodigo = false;
                
                // Mantive o seu banco falso caso use em outro lugar
                BancoFalso.EmailsCadastrados.Add(email); 
            }
            catch (Exception ex)
            {
                respostaBasica = $"Código correto, mas erro ao salvar no banco: {ex.Message}";
                Console.WriteLine($"Erro no Insert: {ex.ToString()}");
            }
        }
        else
        {
            respostaBasica = "Código de verificação incorreto. Tente novamente.";
        }
    }

    private async Task OnClickPessoa(int idade, string nome, string email, string senha)
    {
        var _pessoa = new Pessoa
        {
            Nome = nome,
            Idade = idade,
            Email = email,
            Senha = senha
        };
        await getValidador(_pessoa);
    }

    public class Pessoa
    {
        public string Nome { get; set; } = string.Empty;
        public int Idade { get; set; }
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }
}
